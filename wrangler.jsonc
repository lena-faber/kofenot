// Cloudflare Workers deployment configuration for KOFENOT website.
{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "kofenot",
  "compatibility_date": "2025-09-24",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/server.ts",
  "observability": {
    "logs": {
      "enabled": false,
      "invocation_logs": true
    }
  }
}
